<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Rapido Login Page</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
    }

    body{
        background-color:#f7c600;
        height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
    }

    .container{
        background:white;
        width:500px;
        padding:40px;
        border-radius:15px;
        text-align:center;
        box-shadow:0 5px 20px rgba(0,0,0,0.2);
    }

    .logo{
        font-size:40px;
        font-weight:bold;
        color:black;
        margin-bottom:20px;
    }

    h2{
        color:#222;
        margin-bottom:15px;
    }

    p{
        color:#666;
        line-height:1.8;
    }

    .footer{
        margin-top:25px;
        font-weight:bold;
        color:#f7c600;
        background:black;
        padding:10px;
        border-radius:8px;
    }
</style>

</head>

<body>

<div class="container">

    <div class="logo">RAPIDO</div>

    <h2>Welcome to Rapido Login Portal 🚖</h2>

    <p>
        Login functionality is currently under development.
    </p>

    <p>
        In upcoming versions, users will be able to securely log in,
        manage their profiles, book rides, view ride history,
        and enjoy a seamless Rapido experience.
    </p>

    <p>
        Stay tuned for exciting features and updates!
    </p>

    <div class="footer">
        Work in Progress XD 🚀
    </div>

</div>

</body>
</html>