<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>HDFC Login</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
    }

    body{
        height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        background:linear-gradient(135deg, #004c97, #003366);
    }

    .container{
        background:white;
        width:550px;
        padding:40px;
        border-radius:15px;
        text-align:center;
        box-shadow:0 8px 25px rgba(0,0,0,0.25);
    }

    .logo{
        font-size:42px;
        font-weight:bold;
        color:#004c97;
        margin-bottom:8px;
    }

    .bank{
        color:#e31837;
        font-size:22px;
        font-weight:bold;
        margin-bottom:25px;
    }

    h2{
        color:#333;
        margin-bottom:15px;
    }

    p{
        color:#555;
        line-height:1.8;
        margin-bottom:12px;
    }

    .status{
        margin-top:25px;
        background:#004c97;
        color:white;
        padding:12px;
        border-radius:8px;
        font-weight:bold;
    }

    .note{
        margin-top:15px;
        color:#e31837;
        font-weight:bold;
    }
</style>

</head>

<body>

<div class="container">

    <div class="logo">HDFC</div>
    <div class="bank">Bank Internet Banking</div>

    <h2>Welcome to HDFC Online Banking</h2>

    <p>
        This login module is currently under development.
    </p>

    <p>
        Future versions of this project will allow users to securely
        access their accounts, check balances, transfer funds,
        view transaction history, and manage banking services online.
    </p>

    <p>
        Additional banking features will be implemented in upcoming projects.
    </p>

    <div class="status">
        Work in Progress 🚧
    </div>

    <div class="note">
        Will be implemented in future projects XD!!! 😅
    </div>

</div>

</body>
</html>