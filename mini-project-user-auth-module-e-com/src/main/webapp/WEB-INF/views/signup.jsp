<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Amazon : Signup</title>
</head>
<body>

<form action="signup" method="post">

Full Name : <input type="text" name="fullName" required="required"><br><br>
Email : <input type="text" name="email" required="required"><br><br>
Mobile : <input type="text" name="mobile" required="required"><br><br>
Password : <input type="text" name="password" required="required"><br><br>
Confirm Password : <input type="text" name="confirmPassword" required="required"><br><br>
<input type="submit" value="SignUp">

</form>

</body>
</html>